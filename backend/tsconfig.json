{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "resolveJsonModule": true
  },

  "include": ["src"]
}