{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/entry"
    }
  ],
  "functions": {
    "api/entry": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}
